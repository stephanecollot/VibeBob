{
  "name": "vibebob",
  "private": true,
  "homepage": "https://github.com/stephanecollot/VibeBob",
  "repository": {
    "type": "git",
    "url": "https://github.com/stephanecollot/VibeBob.git"
  },
  "bugs": {
    "url": "https://github.com/stephanecollot/VibeBob/issues"
  },
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "package": "pnpm build && cd dist && zip -r ../vibebob.zip . -x '*.map'",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@heroicons/react": "^2.2.0",
    "@isomorphic-git/lightning-fs": "^4.6.0",
    "buffer": "^6.0.3",
    "isomorphic-git": "^1.27.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "@types/node": "^25.6.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
